cat > .gitignore << 'EOF'
# Flutter & Dart
.dart_tool/
.packages
.pub-cache/
build/
.flutter-plugins
.flutter-plugins-dependencies
.pub/
*.lock

# Generated platform files
android/.gradle/
ios/Flutter/
ios/Pods/
macos/Flutter/ephemeral/
windows/flutter/
linux/flutter/

# IDE
.vscode/
.idea/
*.iml

# OS
.DS_Store
Thumbs.db
EOF

# Flutter / Dart
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
*.dart_tool
*.log

# Web specific - very important
build/web/
*.wasm
*.js.map
canvaskit/

# General
*.env
.DS_Store
Thumbs.db

git add .gitignore
git commit -m "Improve .gitignore - ignore build and generated files"
git push